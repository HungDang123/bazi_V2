APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:2FiByWg+qkolOqdYNX3Ict1t+zQ/TU0mMlXYE6PEw64=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=dev-mysql
DB_PORT=3306
DB_DATABASE=db_vkb
DB_USERNAME=vkbdev
DB_PASSWORD=vkbdev

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database = mặc định ổn với 1–2 worker PDF; redis nhanh hơn khi scale nhiều worker
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis

# PDF export — merge driver: auto|qpdf|pdftk|fpdi (auto thử qpdf/pdftk rồi fallback FPDI)
PDF_MERGE_DRIVER=auto
# PDF_QPDF_BINARY=
# PDF_PDFTK_BINARY=
PDF_LOG_TIMING=true
PDF_QUEUE_Q1=pdf-q1
PDF_QUEUE_Q2=pdf-q2

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
